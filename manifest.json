{
  "manifest_version": 3,
  "name": "Echo · 回声",
  "version": "1.1.0",
  "description": "灵魂连接器 — 不是摘要，是回声",
  
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage"
  ],
  
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://dashscope.aliyuncs.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "action": {
    "default_title": "Echo · 回声"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
